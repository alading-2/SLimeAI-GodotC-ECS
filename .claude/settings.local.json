{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "MultiEdit(*)",
      "Glob(*)",
      "Grep(*)",
      "LS(*)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(passwd *)",
      "Bash(chmod -R 777 *)",
      "Bash(chown -R *)",
      "Bash(rm -rf / *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~ *)",
      "Bash(rm -rf ~/*)",
      "Bash(git push *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fdx *)"
    ]
  }
}